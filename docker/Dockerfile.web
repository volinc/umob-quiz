FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY UmobQuiz.sln ./
COPY src/UmobQuiz.Shared/UmobQuiz.Shared.csproj src/UmobQuiz.Shared/
COPY src/UmobQuiz.Client/UmobQuiz.Client.csproj src/UmobQuiz.Client/
RUN dotnet restore src/UmobQuiz.Client/UmobQuiz.Client.csproj
COPY src/ src/
RUN dotnet publish src/UmobQuiz.Client/UmobQuiz.Client.csproj -c Release -o /app/publish

FROM nginx:1.27-alpine
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/publish/wwwroot /usr/share/nginx/html
EXPOSE 80
