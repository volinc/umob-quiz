@page "/history"
@inject ApiClient ApiClient
@inject FileDownloadService FileDownloadService
@inject AuthState AuthState
@inject NavigationManager Navigation

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h5">Your game history</MudText>
    @if (AuthState.IsAuthenticated)
    {
        <MudTooltip Text="CSV export includes completed games (up to 10,000 per download).">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       Disabled="_exporting"
                       OnClick="ExportCsvAsync">
                @(_exporting ? "Exporting…" : "Export CSV")
            </MudButton>
        </MudTooltip>
    }
</MudStack>

@if (!string.IsNullOrWhiteSpace(_exportError))
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_exportError</MudAlert>
}

@if (!AuthState.IsAuthenticated)
{
    <MudText>Please sign in first.</MudText>
}
else if (_sessions is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_sessions.Count == 0)
{
    <MudText>No completed games yet.</MudText>
}
else
{
    <MudTable Items="_sessions" Hover="true">
        <HeaderContent>
            <MudTh>Started</MudTh>
            <MudTh>Ended</MudTh>
            <MudTh>Score</MudTh>
            <MudTh>Status</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.StartTime.ToLocalTime()</MudTd>
            <MudTd>@(context.EndTime?.ToLocalTime().ToString() ?? "-")</MudTd>
            <MudTd>@context.Score</MudTd>
            <MudTd>@context.Status</MudTd>
        </RowTemplate>
    </MudTable>
}

<MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/game"))">
    Back to game
</MudButton>

@code {
    private IReadOnlyList<GameSessionSummaryDto>? _sessions;
    private bool _exporting;
    private string? _exportError;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        try
        {
            _sessions = await ApiClient.GetHistoryAsync();
        }
        catch (UnauthorizedAccessException)
        {
            return;
        }
    }

    private async Task ExportCsvAsync()
    {
        _exportError = null;
        _exporting = true;

        try
        {
            await FileDownloadService.DownloadHistoryCsvAsync();
        }
        catch (InvalidOperationException ex)
        {
            _exportError = ex.Message;
        }
        catch (HttpRequestException ex)
        {
            _exportError = ex.Message;
        }
        finally
        {
            _exporting = false;
        }
    }
}
